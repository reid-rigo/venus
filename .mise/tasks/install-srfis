#!/bin/sh
set -eu

RAW_DIR="$(mktemp -d)"
OUT_DIR="src/srfi"

echo "Cloning chez-srfi..."
git clone --depth 1 --single-branch \
  https://github.com/arcfide/chez-srfi.git "$RAW_DIR"

echo "Installing SRFI libraries to $OUT_DIR..."
rm -rf "$OUT_DIR"
(cd "$RAW_DIR" && scheme --script install.chezscheme.sps "$(pwd)/..")

echo "Cleaning up..."
rm -rf "$RAW_DIR"

echo "Done — SRFI libraries in $OUT_DIR"
