{
  "name": "vscode-venus",
  "displayName": "Venus",
  "description": "Venus language support",
  "version": "0.1.0",
  "publisher": "venus-lang",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "venus",
      "aliases": ["Venus", "venus"],
      "extensions": [".ve"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icons/venus-file-icon.svg",
        "dark": "./icons/venus-file-icon.svg"
      }
    }],
    "grammars": [{
      "language": "venus",
      "scopeName": "source.venus",
      "path": "./syntaxes/venus.tmLanguage.json"
    }],
    "configurationDefaults": {
      "[venus]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "comment",
              "settings": {
                "foreground": "#888888"
              }
            }
          ]
        }
      }
    }
  }
}
