#!/bin/sh
set -eu

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
mkdir -p "$ROOT/bin"

CHEZ_DIR=$(mise where chezscheme)
CHEZ_LIB="$CHEZ_DIR/lib/csv10.4.1/tarm64osx"

# Compile Scheme sources to shared objects for faster startup
"$CHEZ_DIR/bin/scheme" --script "$ROOT/src/compile.ss"

cc -o "$ROOT/bin/ve" \
  "$ROOT/src/main.c" \
  -I"$CHEZ_LIB" \
  -DCHEZ_BOOT_DIR="\"$CHEZ_LIB\"" \
  "$CHEZ_LIB/libkernel.a" \
  "$CHEZ_LIB/liblz4.a" \
  "$CHEZ_LIB/libz.a" \
  -liconv -lncurses

# marker is bin/ve itself
